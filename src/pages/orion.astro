---
import BaseLayout from '../layouts/BaseLayout.astro';
const code = `#include <orion.h>
int main() {
    OrionModel* model = orion_load("model.orion");
    OrionTensor* out = orion_forward(model, input);
    printf("Result: %f\\n", orion_tensor_get(out, 0));
    orion_free(model);
    return 0;
}`;
---

<BaseLayout title="Orion Engine">
  <section class="hero-pg">
    <div class="container hero-pg-inner">
      <div class="gradient-line"></div>
      <span class="section-label">Flagship Product</span>
      <h1 class="hero-pg-title">
        Orion <span class="gradient-text">Engine</span>
      </h1>
      <p class="hero-pg-sub">
        A new AI engine written in C. Engineered for maximum performance
        in training and inference — outperforming traditional implementations by 33×.
      </p>
      <div class="hero-pg-actions">
        <a href="https://github.com/Solari-Labs/orion" class="btn btn-primary" target="_blank">GitHub →</a>
        <a href="/benchmarks" class="btn btn-secondary">Benchmarks</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cols-3">
        <div class="col">
          <span class="col-n">01</span>
          <h3>Zero Dependencies</h3>
          <p>Pure C99. No Python, no CUDA required. Compiles anywhere.</p>
        </div>
        <div class="col">
          <span class="col-n">02</span>
          <h3>Training + Inference</h3>
          <p>One engine for both workloads. No fragmentation.</p>
        </div>
        <div class="col">
          <span class="col-n">03</span>
          <h3>Cross-Platform</h3>
          <p>Linux, macOS, Windows. x86_64 and ARM.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="code-wrap">
        <span class="section-label">Getting Started</span>
        <h2 class="section-title">Install in <span class="gradient-text">seconds</span></h2>
        <div class="code-block">
          <div class="code-h">
            <span class="cd" style="background:#FF5F56"></span>
            <span class="cd" style="background:#FFBD2E"></span>
            <span class="cd" style="background:#27C93F"></span>
            <span class="cl">bash</span>
          </div>
          <pre>git clone https://github.com/Solari-Labs/orion.git
cd orion && make
./orion run model.orion</pre>
        </div>
        <div class="code-block">
          <div class="code-h">
            <span class="cd" style="background:#FF5F56"></span>
            <span class="cd" style="background:#FFBD2E"></span>
            <span class="cd" style="background:#27C93F"></span>
            <span class="cl">c</span>
          </div>
          <pre set:html={code}></pre>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
.hero-pg {
  padding: 8rem 0 4rem;
  position: relative;
}
.hero-pg-inner { max-width: 640px; }
.hero-pg-title {
  font-size: clamp(2.25rem, 6vw, 4rem);
  font-weight: 800;
  margin-bottom: 1rem;
}
.hero-pg-sub {
  font-size: 1rem;
  color: var(--text-muted);
  max-width: 520px;
  line-height: 1.7;
  margin-bottom: 1.5rem;
}
.hero-pg-actions { display: flex; gap: 0.75rem; }
.cols-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2rem;
}
.col { border-top: 1px solid var(--border); padding-top: 1.5rem; }
.col-n {
  font-family: var(--font-heading);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--text-muted);
  display: block;
  margin-bottom: 0.75rem;
}
.col h3 { font-size: 1.15rem; margin-bottom: 0.5rem; }
.col p { font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; }
.code-wrap { max-width: 640px; }
.code-block {
  background: #0A0808; border: 1px solid var(--border);
  border-radius: var(--radius); overflow: hidden; margin-top: 1rem;
}
.code-h {
  display: flex; align-items: center; gap: 6px;
  padding: 10px 14px; border-bottom: 1px solid var(--border);
  background: var(--bg-elevated);
}
.cd { width: 10px; height: 10px; border-radius: 50%; }
.cl {
  margin-left: auto; font-family: var(--font-heading);
  font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase;
  letter-spacing: 0.08em;
}
.code-block pre {
  padding: 1rem 1.25rem; overflow-x: auto;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.8rem; line-height: 1.6;
  color: #E8DCC8;
}
@media (max-width: 600px) {
  .cols-3 { grid-template-columns: 1fr; }
  .hero-pg-actions { flex-direction: column; }
}
</style>
