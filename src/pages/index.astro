---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="Home">
  <Hero />

  <section class="section">
    <div class="container">
      <div class="intro">
        <div class="gradient-line"></div>
        <h2 class="section-title">
          We built <span class="gradient-text">Orion</span>
        </h2>
        <p class="section-text">
          An AI engine written entirely in C. Designed for training and inference,
          it redefines what's possible on consumer hardware. 33× faster than
          traditional stacks.
        </p>
        <div class="intro-links">
          <a href="/orion" class="btn btn-primary">Explore Orion →</a>
          <a href="/benchmarks" class="btn btn-secondary">See Benchmarks</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="stat-row">
        <div class="stat">
          <span class="stat-n gradient-text">33×</span>
          <span class="stat-l">Faster</span>
        </div>
        <div class="stat">
          <span class="stat-n gradient-text">C99</span>
          <span class="stat-l">Native</span>
        </div>
        <div class="stat">
          <span class="stat-n gradient-text">0</span>
          <span class="stat-l">Dependencies</span>
        </div>
        <div class="stat">
          <span class="stat-n gradient-text">100%</span>
          <span class="stat-l">Open Source</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
.intro {
  max-width: 640px;
}
.intro-links {
  display: flex; gap: 0.75rem; margin-top: 2rem;
}
.section-alt {
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  background: var(--bg-elevated);
}
.stat-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
  text-align: center;
}
.stat {
  display: flex; flex-direction: column; gap: 0.25rem;
}
.stat-n {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 800;
  letter-spacing: -0.04em;
}
.stat-l {
  font-size: 0.85rem;
  color: var(--text-muted);
  font-weight: 500;
}
@media (max-width: 600px) {
  .stat-row { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .intro-links { flex-direction: column; }
}
</style>
