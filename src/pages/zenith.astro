---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Zenith Models">
  <section class="hero-pg">
    <div class="container hero-pg-inner">
      <div class="gradient-line"></div>
      <span class="section-label">Open Source</span>
      <h1 class="hero-pg-title">
        Zenith <span class="gradient-text">Models</span>
      </h1>
      <p class="hero-pg-sub">
        AI models trained on a laptop — proving Orion democratizes access
        to artificial intelligence. No clusters, just efficient code.
      </p>
      <div class="hero-pg-actions">
        <a href="https://github.com/Solari-Labs/zenith" class="btn btn-primary" target="_blank">GitHub →</a>
        <a href="/orion" class="btn btn-secondary">Meet Orion</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cols-3">
        <div class="col">
          <div class="col-h">
            <span class="col-badge">Flagship</span>
            <span class="col-size">1.2B</span>
          </div>
          <h3>Zenith-1B</h3>
          <p>Matches 7B model performance thanks to Orion's efficiency.</p>
          <div class="col-meta">
            <span>Trained in 48h</span>
            <span>RTX 4060 Laptop</span>
          </div>
        </div>
        <div class="col">
          <div class="col-h">
            <span class="col-badge col-badge--code">Code</span>
            <span class="col-size">350M</span>
          </div>
          <h3>Zenith-Coder</h3>
          <p>Specialized in code generation. Trained on high-quality GitHub data.</p>
          <div class="col-meta">
            <span>Trained in 24h</span>
            <span>RTX 4060 Laptop</span>
          </div>
        </div>
        <div class="col">
          <div class="col-h">
            <span class="col-badge col-badge--math">Math</span>
            <span class="col-size">700M</span>
          </div>
          <h3>Zenith-Math</h3>
          <p>Outperforms models 5× larger on GSM8K benchmarks.</p>
          <div class="col-meta">
            <span>Trained in 36h</span>
            <span>RTX 4060 Laptop</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="specs">
        <div class="gradient-line"></div>
        <span class="section-label">Proof</span>
        <h2 class="section-title">Trained on a <span class="gradient-text">laptop</span></h2>
        <p class="section-text">
          A laptop with an RTX 4060. Orion compiled. Functional models in 48 hours.
        </p>
        <div class="specs-table">
          <div class="spec-row"><span>Hardware</span><span>Laptop RTX 4060 8GB</span></div>
          <div class="spec-row"><span>Time</span><span>24–48 hours per model</span></div>
          <div class="spec-row"><span>Framework</span><span>Orion Engine (C)</span></div>
          <div class="spec-row"><span>Cost</span><span>~$5 USD electricity</span></div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
.col-h {
  display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;
}
.col-badge {
  font-family: var(--font-heading);
  font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 3px 10px; border-radius: 4px;
  background: var(--accent); color: var(--bg);
}
.col-badge--code { background: var(--accent-secondary); color: var(--bg); }
.col-badge--math { background: #D65A28; color: white; }
.col-size {
  font-family: var(--font-heading); font-weight: 800; font-size: 1.25rem;
}
.col-meta {
  display: flex; gap: 1rem; margin-top: 1rem;
  font-size: 0.8rem; color: var(--text-muted);
}
.specs { max-width: 560px; }
.specs-table {
  margin-top: 1.5rem;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}
.spec-row {
  display: flex; justify-content: space-between;
  padding: 0.75rem 1.25rem;
  border-bottom: 1px solid var(--border);
  font-size: 0.85rem;
}
.spec-row:last-child { border-bottom: none; }
.spec-row span:first-child { color: var(--text-muted); }
.spec-row span:last-child { font-weight: 600; }
</style>
