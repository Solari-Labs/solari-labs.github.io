---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact">
  <section class="hero-pg">
    <div class="container hero-pg-inner">
      <div class="gradient-line"></div>
      <span class="section-label">Connect</span>
      <h1 class="hero-pg-title">
        Let's Talk <span class="gradient-text">→</span>
      </h1>
      <p class="hero-pg-sub">
        Want to try Orion? Have questions? We'd love to hear from you.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-cards">
          <div class="contact-card">
            <span class="contact-icon">📧</span>
            <h3>Email</h3>
            <a href="mailto:hello@solari-labs.com">hello@solari-labs.com</a>
          </div>
          <div class="contact-card">
            <span class="contact-icon">🐙</span>
            <h3>GitHub</h3>
            <a href="https://github.com/Solari-Labs" target="_blank">github.com/Solari-Labs</a>
          </div>
          <div class="contact-card">
            <span class="contact-icon">📍</span>
            <h3>Location</h3>
            <p>Mexico</p>
          </div>
        </div>
        <form class="contact-form" id="cf">
          <h3 style="margin-bottom:1.5rem">Send a message</h3>
          <div class="fg">
            <label for="name">Name</label>
            <input type="text" id="name" required placeholder="Your name" />
          </div>
          <div class="fg">
            <label for="email">Email</label>
            <input type="email" id="email" required placeholder="you@email.com" />
          </div>
          <div class="fg">
            <label for="subject">Subject</label>
            <select id="subject">
              <option value="orion">Orion Engine</option>
              <option value="zenith">Zenith Models</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="fg">
            <label for="msg">Message</label>
            <textarea id="msg" rows="4" required placeholder="Tell us..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Send →</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 3rem;
  align-items: start;
}
.contact-cards {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.contact-card {
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.25rem;
}
.contact-icon { font-size: 1.25rem; line-height: 1; display: block; margin-bottom: 0.5rem; }
.contact-card h3 { font-size: 0.95rem; margin-bottom: 0.25rem; }
.contact-card p { font-size: 0.85rem; color: var(--text-muted); }
.contact-card a { font-size: 0.85rem; color: var(--accent); font-weight: 500; }
.contact-form {
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 1.5rem;
}
.fg { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1rem; }
.fg label {
  font-family: var(--font-heading); font-size: 0.8rem; font-weight: 600;
  color: var(--text-muted);
}
.fg input, .fg select, .fg textarea {
  font-family: var(--font-body); font-size: 0.9rem;
  padding: 0.65rem 0.85rem;
  border: 1px solid var(--border); border-radius: 6px;
  background: var(--bg); color: var(--text);
  outline: none; transition: border-color 0.2s;
}
.fg input:focus, .fg select:focus, .fg textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 2px var(--accent-glow);
}
.fg textarea { resize: vertical; }
@media (max-width: 600px) {
  .contact-grid { grid-template-columns: 1fr; }
}
</style>

<script>
  document.getElementById('cf')?.addEventListener('submit', e => {
    e.preventDefault();
    alert('Thanks for your message. We\'ll be in touch.');
  });
</script>
