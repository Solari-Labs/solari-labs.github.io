---
const path = Astro.url.pathname;
const links = [
  { href: '/', label: 'Home' },
  { href: '/orion', label: 'Orion' },
  { href: '/zenith', label: 'Zenith' },
  { href: '/benchmarks', label: 'Benchmarks' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <img src="/logo.png" alt="Solari Labs" class="logo-img" width="28" height="28" />
      <span>Solari<span class="logo-a">Labs</span></span>
    </a>
    <nav class="nav">
      {links.map(l => (
        <a href={l.href} class:list={{ link: true, active: path === l.href }}>{l.label}</a>
      ))}
    </nav>
    <button class="theme-btn" id="t" aria-label="Theme">
      <span class="d">☾</span><span class="l">☀</span>
    </button>
  </div>
</header>

<style is:global>
.header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  height: var(--header-h);
  background: rgba(7,5,4,0.85);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
}
[data-theme="light"] .header { background: rgba(245,240,235,0.9); }
.header-inner {
  display: flex; align-items: center; justify-content: space-between; height: 100%;
}
.logo {
  display: flex; align-items: center; gap: 8px;
  font-family: var(--font-heading); font-weight: 800; font-size: 1.1rem;
  letter-spacing: -0.03em;
}
.logo-img { border-radius: 50%; flex-shrink: 0; }
.logo-a { color: var(--accent); }
.nav { display: flex; gap: 2px; }
.link {
  padding: 6px 14px; border-radius: 6px;
  font-size: 0.85rem; font-weight: 500; color: var(--text-muted);
  transition: all 0.2s;
}
.link:hover { color: var(--text); background: rgba(255,255,255,0.04); }
.active { color: var(--accent) !important; background: rgba(255,107,53,0.08); }
.theme-btn {
  background: none; border: 1px solid var(--border); border-radius: 6px;
  padding: 6px 10px; cursor: pointer; color: var(--text-muted); font-size: 1rem;
  line-height: 1;
}
.theme-btn:hover { color: var(--accent); border-color: var(--accent); }
[data-theme="dark"] .l { display: none; }
[data-theme="light"] .d { display: none; }
@media (max-width: 640px) { .nav { display: none; } }
</style>

<script>
  document.getElementById('t')?.addEventListener('click', () => {
    const h = document.documentElement;
    const n = h.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    h.setAttribute('data-theme', n);
    localStorage.setItem('theme', n);
  });
</script>
