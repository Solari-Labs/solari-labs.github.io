<canvas id="hc"></canvas>
<section class="hero">
  <div class="hero-shape"></div>
  <div class="container hero-inner">
    <div class="hero-content">
      <div class="gradient-line"></div>
      <p class="hero-badge">New AI Engine</p>
      <h1 class="hero-title">
        <span>Powering the</span>
        <span class="gradient-text">Next AI Revolution</span>
      </h1>
      <p class="hero-sub">
        Written in C. 33× faster. Completely open source.
      </p>
      <div class="hero-actions">
        <a href="/orion" class="btn btn-primary">Meet Orion →</a>
        <a href="https://github.com/Solari-Labs" class="btn btn-secondary" target="_blank">GitHub ↗</a>
      </div>
    </div>
  </div>
</section>

<style is:global>
#hc {
  position: absolute; inset: 0; z-index: 0; pointer-events: none;
}
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
  padding-top: var(--header-h);
}
.hero-shape {
  position: absolute;
  top: -20%; right: -10%;
  width: 60vmax; height: 60vmax;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,107,53,0.08), transparent 60%);
  pointer-events: none;
}
.hero-inner {
  position: relative; z-index: 1;
  display: flex; align-items: center;
}
.hero-content { max-width: 640px; }
.hero-badge {
  font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.15em; color: var(--accent); margin-bottom: 1rem;
  opacity: 0; animation: f 0.8s ease forwards;
}
.hero-title {
  font-size: clamp(2.5rem, 7vw, 4.5rem);
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 1.05;
}
.hero-title span { display: block; opacity: 0; animation: f 0.8s ease forwards; }
.hero-title span:nth-child(2) { animation-delay: 0.15s; }
.hero-title span:nth-child(3) { animation-delay: 0.3s; }
.hero-sub {
  font-size: 1rem; color: var(--text-muted); margin-top: 1.25rem; max-width: 420px;
  opacity: 0; animation: f 0.8s ease 0.4s forwards;
}
.hero-actions {
  display: flex; gap: 0.75rem; margin-top: 2rem;
  opacity: 0; animation: f 0.8s ease 0.55s forwards;
}
@keyframes f {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}
@media (max-width: 600px) {
  .hero { min-height: 90vh; }
  .hero-actions { flex-direction: column; align-items: flex-start; }
}
</style>

<script>
  const c = document.getElementById('hc');
  if (!c) throw new Error('no canvas');
  const x = c.getContext('2d');
  let w, h, p = [], mx = 0, my = 0;

  const rs = () => {
    const el = c.parentElement;
    w = c.width = el.offsetWidth;
    h = c.height = el.offsetHeight;
  };

  class Pt {
    constructor() { this.r(); }
    r() {
      this.x = Math.random() * w;
      this.y = Math.random() * h;
      this.s = Math.random() * 2 + 0.5;
      this.vx = (Math.random() - 0.5) * 0.4;
      this.vy = (Math.random() - 0.5) * 0.4;
      this.o = Math.random() * 0.5 + 0.15;
      this.h = Math.random() < 0.5 ? 18 + Math.random() * 15 : 32 + Math.random() * 15;
    }
    u() {
      this.x += this.vx; this.y += this.vy;
      const dx = mx - this.x, dy = my - this.y, d = Math.sqrt(dx*dx+dy*dy);
      if (d < 150) { const f = (150-d)/150*0.2; this.x -= dx*f*0.01; this.y -= dy*f*0.01; }
      if (this.x < 0 || this.x > w || this.y < 0 || this.y > h) this.r();
    }
  }

  const init = () => {
    rs();
    const ct = Math.min(Math.floor((w*h)/10000), 80);
    p = Array.from({length: ct}, () => new Pt());
  };

  const dr = () => {
    x.clearRect(0, 0, w, h);
    const lt = document.documentElement.getAttribute('data-theme') === 'light';
    for (const pt of p) {
      pt.u();
      const a = lt ? pt.o * 0.35 : pt.o;
      x.beginPath();
      x.arc(pt.x, pt.y, pt.s, 0, Math.PI * 2);
      x.fillStyle = `hsla(${pt.h}, 85%, ${lt ? 45 : 58}%, ${a})`;
      x.fill();
      if (pt.s > 1.3) {
        x.beginPath();
        x.arc(pt.x, pt.y, pt.s * 2.5, 0, Math.PI * 2);
        x.fillStyle = `hsla(${pt.h}, 85%, ${lt ? 45 : 58}%, ${a * 0.12})`;
        x.fill();
      }
    }
    requestAnimationFrame(dr);
  };

  init();
  dr();
  window.addEventListener('resize', () => { rs(); });
  window.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
  window.addEventListener('touchmove', e => { if (e.touches[0]) { mx = e.touches[0].clientX; my = e.touches[0].clientY; } });
</script>
