---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Solari Labs</title>
    <meta name="description" content="Powering the next AI revolution" />
    <meta name="theme-color" content="#070504" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script>const s=localStorage.getItem('theme');if(s)document.documentElement.setAttribute('data-theme',s);</script>
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
  </body>
</html>
